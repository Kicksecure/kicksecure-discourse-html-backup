<aside class="onebox githubblob" data-onebox-src="https://github.com/Kicksecure/user-sysmaint-split/blob/master/usr/libexec/user-sysmaint-split/sysmaint-boot#L365-L367">
  <header class="source">

      <a href="https://github.com/Kicksecure/user-sysmaint-split/blob/master/usr/libexec/user-sysmaint-split/sysmaint-boot#L365-L367" target="_blank" rel="noopener">github.com/Kicksecure/user-sysmaint-split</a>
  </header>

  <article class="onebox-body">
    <h4><a href="https://github.com/Kicksecure/user-sysmaint-split/blob/master/usr/libexec/user-sysmaint-split/sysmaint-boot#L365-L367" target="_blank" rel="noopener">usr/libexec/user-sysmaint-split/sysmaint-boot</a></h4>

<div class="git-blob-info">
  <a href="https://github.com/Kicksecure/user-sysmaint-split/blob/master/usr/libexec/user-sysmaint-split/sysmaint-boot#L365-L367" rel="noopener"><code>master</code></a>
</div>



    <pre class="onebox"><code class="lang-">
      <ol class="start lines" start="365" style="counter-reset: li-counter 364 ;">
          <li>while read -r rpc_config_file; do</li>
          <li>   cp -- '/usr/libexec/user-sysmaint-split/qubes-rpc-block' "/run/qubes-rpc/${rpc_config_file}"</li>
          <li>done &lt; /usr/share/user-sysmaint-split/qubes-rpc-blocks</li>
      </ol>
    </code></pre>



  </article>

